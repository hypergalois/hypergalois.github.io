---
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import { researchLines } from '@/data/researchLines';
import { cvRecords, education } from '@/data/profile';
---

<PageLayout
  title="About"
  description="José Luis Delgado: research engineering across systems security, cryptographic infrastructure, formal methods, and AI evaluation."
  eagerReveal
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="user-round" size="sm" />
      About
    </Badge>

    <h1 slot="title">José Luis Delgado.</h1>

    <p slot="description">
      Research engineering across systems security, cryptographic infrastructure,
      formal methods, and AI evaluation.
    </p>
  </Hero>

  <section class="border-t border-border bg-background-secondary py-[var(--space-section-lg)]">
    <div class="mx-auto grid max-w-5xl gap-8 px-6 lg:grid-cols-[1fr_0.85fr]">
      <div class="flex flex-col justify-center gap-5" data-reveal="right">
        <Badge variant="brand" pill class="self-start">Profile</Badge>
        <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
          Security systems, formal reasoning, and research tooling.
        </h2>
        <p class="text-lg leading-relaxed text-foreground-muted">
          The work is organized around papers. Each paper states the object,
          method, and evidence, then links to PDF and code when those are public.
        </p>
        <p class="text-lg leading-relaxed text-foreground-muted">
          The current focus is post-quantum migration, certificate assurance,
          executable models, and evaluation records for tool-using AI systems.
        </p>
      </div>

      <Card variant="elevated" padding="lg" class="h-fit" data-reveal="left" data-reveal-delay="1">
        <div class="mb-6 flex items-center justify-between gap-4">
          <div>
            <p class="text-xs font-bold uppercase tracking-wider text-foreground-muted">Research record</p>
            <h3 class="mt-1 font-display text-2xl font-bold text-foreground">José Luis Delgado</h3>
          </div>
          <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500/25 to-brand-500/5 text-brand-500">
            <Icon name="atom" size="lg" />
          </div>
        </div>
        <div class="grid gap-3">
          {cvRecords.map((record) => (
            <div class="rounded-lg border border-border bg-background px-4 py-3">
              <p class="text-xs font-bold uppercase tracking-wider text-foreground-muted">{record.label}</p>
              <p class="mt-1 text-sm leading-relaxed text-foreground">{record.value}</p>
            </div>
          ))}
        </div>
      </Card>
    </div>
  </section>

  <section class="border-t border-border bg-background py-[var(--space-section-lg)]">
    <div class="mx-auto flex max-w-5xl flex-col gap-8 px-6">
      <div class="max-w-2xl" data-reveal>
        <Badge variant="brand" pill class="mb-5">Research lines</Badge>
        <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
          Two lines, one paper index.
        </h2>
      </div>

      <div class="grid gap-5 md:grid-cols-2">
        {researchLines.map((line) => (
          <Card hover padding="lg" href={`/#${line.id}`} class="group border-border-strong bg-background-tertiary/70" data-reveal>
            <div class="flex h-full flex-col gap-5">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-xs font-bold uppercase tracking-wider text-brand-500">{line.eyebrow}</p>
                  <h3 class="mt-2 font-display text-2xl font-bold text-foreground transition-colors group-hover:text-brand-500">
                    {line.title}
                  </h3>
                </div>
                <Icon name={line.icon} size="md" class="shrink-0 text-brand-500" />
              </div>
              <p class="text-sm leading-relaxed text-foreground-muted">{line.description}</p>
              <div class="mt-auto flex flex-wrap gap-2">
                {line.objects.map((object) => <Badge variant="brand">{object}</Badge>)}
              </div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-background-secondary py-[var(--space-section-lg)]">
    <div class="mx-auto grid max-w-5xl gap-8 px-6 lg:grid-cols-[0.85fr_1.15fr]">
      <div class="flex flex-col gap-5" data-reveal="right">
        <Badge variant="brand" pill class="self-start">CV</Badge>
        <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
          Academic and research record.
        </h2>
        <p class="text-lg leading-relaxed text-foreground-muted">
          Concise academic context for reviewers who want the background before
          reading the papers.
        </p>
      </div>

      <div class="grid gap-4" data-reveal="left" data-reveal-delay="1">
        {education.map((entry) => (
          <Card padding="lg" class="border-border-strong bg-background-tertiary/70">
            <div class="flex flex-col gap-4">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                  <p class="text-xs font-bold uppercase tracking-wider text-brand-500">{entry.period}</p>
                  <h3 class="mt-1 font-display text-xl font-bold text-foreground">{entry.title}</h3>
                  <p class="mt-1 text-sm text-foreground-muted">{entry.institution}</p>
                </div>
                <Icon name="graduation-cap" size="md" class="text-brand-500" />
              </div>
              <ul class="space-y-2">
                {entry.details.map((detail) => (
                  <li class="flex gap-2 text-sm leading-relaxed text-foreground-muted">
                    <Icon name="dot" size="sm" class="mt-1 shrink-0 text-brand-500" />
                    <span>{detail}</span>
                  </li>
                ))}
              </ul>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-background py-[var(--space-section-md)]">
    <div class="mx-auto flex max-w-5xl flex-col gap-6 px-6 md:flex-row md:items-center md:justify-between" data-reveal>
      <div>
        <Badge variant="brand" pill class="mb-5">Papers</Badge>
        <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
          Start with the paper index.
        </h2>
      </div>
      <div class="flex flex-wrap gap-3">
        <Button size="lg" href="/papers">
          Papers
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/contact">
          Contact
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>
</PageLayout>
