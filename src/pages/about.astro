---
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
import { cvRecords, education, researchMethods } from '@/data/profile';

const principles = [
  {
    icon: 'scan-search',
    title: 'Measure the boundary',
    body: 'Collect traces, certificates, logs, parser behavior, and operational defaults where protocol assumptions meet deployed systems.',
  },
  {
    icon: 'sigma',
    title: 'Model the claim',
    body: 'Name the state, transitions, invariants, threat model, and failure modes that support the security argument.',
  },
  {
    icon: 'git-branch',
    title: 'Keep the record inspectable',
    body: 'Keep research code readable, reproducible, and documented enough for later inspection.',
  },
];

const profileSignals = [
  'Systems security',
  'Cryptographic infrastructure',
  'Formal methods',
  'Post-quantum migration',
  'Protocol measurement',
  'Agentic evaluation',
];
---

<PageLayout
  title="Profile"
  description="A research engineering profile focused on security infrastructure, formal methods, cryptography, and high-assurance systems."
  eagerReveal
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="user-round" size="sm" />
      Profile
    </Badge>

    <h1 slot="title">Systems security, formal models, measurement.</h1>

    <p slot="description">
      Research engineering across protocol behavior, certificate infrastructure,
      formal reasoning, and evaluation harnesses for automated workflows.
    </p>
  </Hero>

  <section class="border-t border-border bg-background-secondary py-[var(--space-section-md)]">
    <div class="mx-auto grid max-w-6xl gap-10 px-6 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="flex flex-col justify-center gap-5" data-reveal="right">
        <Badge variant="brand" pill class="self-start">Research posture</Badge>
        <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
          Write the claim, test the system, show the boundary.
        </h2>
        <p class="text-lg leading-relaxed text-foreground-muted">
          My work sits around systems security, cryptographic infrastructure,
          formal methods, and research tooling. The common object is a technical
          claim supported by code, traces, models, or reproducible experiments.
        </p>
        <p class="text-lg leading-relaxed text-foreground-muted">
          The portfolio favors paper pages with question, method, evidence,
          implementation notes, results, and scope.
        </p>
      </div>

      <Card variant="elevated" padding="lg" class="h-full overflow-hidden" data-reveal="left" data-reveal-delay="1">
        <div class="mb-8 flex items-center justify-between gap-4">
          <div>
            <p class="text-xs font-bold uppercase tracking-wider text-foreground-muted">Profile signal</p>
            <h3 class="mt-1 font-display text-2xl font-bold text-foreground">José Luis Delgado</h3>
            <p class="mt-1 text-sm text-foreground-muted">Research engineering</p>
          </div>
          <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-brand-500/30 to-brand-500/5 text-brand-500">
            <Icon name="atom" size="lg" />
          </div>
        </div>
        <div class="grid gap-2">
          {profileSignals.map((signal) => (
            <div class="rounded-xl border border-border bg-background px-4 py-3 text-sm font-medium text-foreground">
              {signal}
            </div>
          ))}
        </div>
      </Card>
    </div>
  </section>

  <section class="border-t border-border bg-background py-[var(--space-section-md)]">
    <div class="mx-auto grid max-w-6xl gap-8 px-6 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="flex flex-col gap-5" data-reveal="right">
        <Badge variant="brand" pill class="self-start">CV record</Badge>
        <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
          Education and research profile.
        </h2>
        <p class="text-lg leading-relaxed text-foreground-muted">
          Academic record, research areas, and working methods for the papers and notes.
        </p>
        <div class="grid gap-2 sm:grid-cols-2">
          {cvRecords.map((record) => (
            <div class="rounded-lg border border-border bg-background-secondary p-4">
              <p class="text-xs font-bold uppercase tracking-wider text-foreground-muted">{record.label}</p>
              <p class="mt-2 text-sm leading-relaxed text-foreground">{record.value}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="grid gap-4" data-reveal="left" data-reveal-delay="1">
        {education.map((entry) => (
          <Card padding="lg">
            <div class="flex flex-col gap-4">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                  <p class="text-xs font-bold uppercase tracking-wider text-brand-500">{entry.period}</p>
                  <h3 class="mt-1 font-display text-xl font-bold text-foreground">{entry.title}</h3>
                  <p class="mt-1 text-sm text-foreground-muted">{entry.institution}</p>
                </div>
                <Icon name="graduation-cap" size="md" class="text-brand-500" />
              </div>
              <ul class="space-y-2">
                {entry.details.map((detail) => (
                  <li class="flex gap-2 text-sm leading-relaxed text-foreground-muted">
                    <Icon name="dot" size="sm" class="mt-1 shrink-0 text-brand-500" />
                    <span>{detail}</span>
                  </li>
                ))}
              </ul>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-background-secondary py-[var(--space-section-md)]">
    <div class="mx-auto flex max-w-6xl flex-col gap-8 px-6">
      <div class="text-center" data-reveal>
        <Badge variant="brand" pill class="mb-5">Working principles</Badge>
        <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
          Working principles.
        </h2>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {principles.map((item, index) => (
          <Card hover data-reveal data-reveal-delay={index}>
            <div class="flex h-full flex-col gap-5">
              <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 text-brand-500">
                <Icon name={item.icon} size="md" />
              </div>
              <div>
                <h3 class="text-base font-semibold text-foreground">{item.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-foreground-muted">{item.body}</p>
              </div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-background py-[var(--space-section-md)]">
    <div class="mx-auto grid max-w-6xl gap-8 px-6 lg:grid-cols-[0.95fr_1.05fr]">
      <Card variant="elevated" padding="lg" data-reveal="right">
        <Badge variant="brand" pill class="mb-6">Research fit</Badge>
        <h2 class="font-display text-3xl font-bold text-foreground">
          Problems, methods, evidence.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-foreground-muted">
          Work is grouped by systems questions: post-quantum migration,
          certificate assurance, formal models, boundary tests, and evaluation harnesses.
        </p>
      </Card>

      <Card variant="elevated" padding="lg" data-reveal="left" data-reveal-delay="1">
        <Badge variant="brand" pill class="mb-6">Methods</Badge>
        <h2 class="font-display text-3xl font-bold text-foreground">
          Methods visible at a glance.
        </h2>
        <div class="mt-5 flex flex-wrap gap-2">
          {researchMethods.map((method) => <Badge variant="brand">{method}</Badge>)}
        </div>
      </Card>
    </div>
  </section>

  <section class="relative z-10 border-t border-border bg-background py-[var(--space-section-md)]">
    <div class="glitch:hidden mx-auto max-w-2xl px-6 text-center" data-reveal>
      <Badge variant="brand" pill class="mb-6">Next</Badge>
      <h2 class="mb-4 font-display text-4xl font-bold text-foreground text-balance">
        Papers carry the work.
      </h2>
      <p class="mb-8 text-lg text-foreground-muted text-balance">
        Each paper links the surrounding technical material; this page gives the frame.
      </p>
      <Button size="lg" href="/papers" class="cta-btn-brand">
        Read papers
        <Icon name="arrow-right" size="sm" />
      </Button>
    </div>

    <LetterGlitchBand>
      <h2 class="mb-4 font-display text-4xl font-bold text-foreground text-balance">
        Papers carry the work.
      </h2>
      <p class="mb-8 text-lg text-foreground-muted text-balance">
        Each paper links the surrounding technical material; this page gives the frame.
      </p>
      <div class="flex flex-col justify-center gap-4 sm:flex-row">
        <Button size="lg" href="/papers" class="hero-btn-brand">
          Read papers
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/contact">
          Contact
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </LetterGlitchBand>
  </section>
</PageLayout>
