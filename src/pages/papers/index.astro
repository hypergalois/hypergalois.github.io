---
import PageLayout from '@/layouts/PageLayout.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { Hero } from '@/components/hero';
import { researchLines } from '@/data/researchLines';
import { getCollection } from 'astro:content';

const items = await getCollection('papers', ({ data }) => !data.draft);
const papers = items.sort((a, b) => a.data.order - b.data.order);

const paperHref = (id: string) => `/papers/${id.replace(/\.mdx?$/, '')}`;

const lineGroups = researchLines.map((line) => ({
  ...line,
  papers: papers.filter((paper) => paper.data.line === line.id),
}));
---

<PageLayout
  title="Papers"
  description="Papers grouped by research line, with context and supporting technical material attached."
  eagerReveal
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="file-text" size="sm" />
      Papers
    </Badge>

    <h1 slot="title">Papers by research line.</h1>

    <p slot="description">
      Each paper opens into a readable explanation and keeps the supporting material close.
    </p>
  </Hero>

  {lineGroups.map((line, index) => (
    <section class={`border-t border-border ${index % 2 === 0 ? 'bg-background-secondary' : 'bg-background'} py-[var(--space-section-lg)]`}>
      <div class="mx-auto flex max-w-5xl flex-col gap-10 px-6">
        <div class="grid gap-6 lg:grid-cols-[0.85fr_1.15fr]" data-reveal>
          <div class="flex flex-col gap-5">
            <Badge variant="brand" pill class="self-start">{line.eyebrow}</Badge>
            <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
              {line.title}
            </h2>
          </div>
          <p class="self-end text-lg leading-relaxed text-foreground-muted">
            {line.evidence}
          </p>
        </div>

        {line.papers.length > 0 ? (
          <div class="grid gap-6 md:grid-cols-2">
            {line.papers.map((paper) => (
              <Card variant="elevated" padding="lg" class="flex min-h-[18rem] flex-col gap-5 border-border-strong bg-background-tertiary/70" data-reveal>
                <div>
                  <div class="mb-5 flex items-start justify-between gap-4">
                    <div class="flex flex-wrap gap-1.5">
                      <Badge variant="brand">{paper.data.status}</Badge>
                      {paper.data.year && <Badge>{paper.data.year}</Badge>}
                    </div>
                    <Icon name={line.icon} size="sm" class="shrink-0 text-brand-500" />
                  </div>
                  <a href={paperHref(paper.id)} class="font-display text-2xl font-bold text-foreground transition-colors hover:text-brand-500">
                    {paper.data.title}
                  </a>
                  <p class="mt-3 text-sm leading-relaxed text-foreground-muted">{paper.data.description}</p>
                </div>

                <div class="mt-auto flex flex-wrap gap-2">
                  <Button size="sm" href={paperHref(paper.id)}>
                    <Icon name="file-text" size="sm" />
                    Read paper
                  </Button>
                  {paper.data.project && (
                    <Button size="sm" variant="outline" href={paper.data.project}>
                      <Icon name="file-code-2" size="sm" />
                      Material
                    </Button>
                  )}
                </div>
              </Card>
            ))}
          </div>
        ) : (
          <Card padding="lg" data-reveal>
            <p class="text-sm leading-relaxed text-foreground-muted">
              Manuscript records for this line will appear here.
            </p>
          </Card>
        )}
      </div>
    </section>
  ))}

</PageLayout>
