---
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import { researchLines } from '@/data/researchLines';
import { getCollection } from 'astro:content';

const items = await getCollection('projects', ({ data }) => !data.draft);
const projects = items.sort((a, b) => a.data.order - b.data.order);

const slug = (id: string) => id.replace(/\.mdx?$/, '');
const projectHref = (id: string) => `/projects/${slug(id)}`;

const lineGroups = researchLines.map((line) => ({
  ...line,
  projects: projects.filter((project) => project.data.line === line.id),
}));
---

<PageLayout
  title="Technical material"
  description="Supporting code pages, measurement harnesses, models, and implementation records linked from papers."
  eagerReveal
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="layers" size="sm" />
      Material
    </Badge>

    <h1 slot="title">Technical material.</h1>

    <p slot="description">
      Code pages, harnesses, models, and implementation records used by the papers.
    </p>
  </Hero>

  {lineGroups.map((line, index) => (
    <section class={`border-t border-border ${index % 2 === 0 ? 'bg-background-secondary' : 'bg-background'} py-[var(--space-section-md)]`}>
      <div class="mx-auto flex max-w-6xl flex-col gap-8 px-6">
        <div class="grid gap-6 lg:grid-cols-[0.88fr_1.12fr]" data-reveal>
          <div class="flex flex-col gap-5">
            <Badge variant="brand" pill class="self-start">{line.eyebrow}</Badge>
            <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
              {line.title}
            </h2>
          </div>
          <div class="flex flex-col justify-end gap-4">
            <p class="text-lg leading-relaxed text-foreground-muted">{line.description}</p>
            <div class="flex flex-wrap gap-2">
              {line.objects.map((object) => <Badge variant="brand">{object}</Badge>)}
            </div>
          </div>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          {line.projects.map((project) => (
            <Card variant="elevated" hover padding="lg" href={projectHref(project.id)} class="group flex min-h-[18rem] flex-col" data-reveal>
              <div class="mb-5 flex items-start justify-between gap-4">
                <div class="flex flex-wrap gap-1.5">
                  {project.data.tags.slice(0, 4).map((tag) => <Badge variant="brand">{tag}</Badge>)}
                </div>
                <Icon name="arrow-up-right" size="sm" class="shrink-0 text-foreground-muted transition-colors group-hover:text-brand-500" />
              </div>
              <div class="mb-2 flex items-baseline gap-2">
                <h3 class="font-display text-xl font-bold text-foreground">{project.data.title}</h3>
                {project.data.year && <span class="text-xs text-foreground-muted">{project.data.year}</span>}
              </div>
              <p class="flex-1 text-sm leading-relaxed text-foreground-muted">{project.data.description}</p>
              <div class="mt-6 flex flex-wrap gap-4 text-sm text-foreground-muted">
                {project.data.role && <span>{project.data.role}</span>}
                {project.data.services.length > 0 && <span>{project.data.services.slice(0, 2).join(' · ')}</span>}
              </div>
            </Card>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="border-t border-border bg-background-secondary py-[var(--space-section-md)]">
    <div class="mx-auto flex max-w-6xl flex-col gap-6 px-6 md:flex-row md:items-center md:justify-between" data-reveal>
      <div>
        <Badge variant="brand" pill class="mb-5">Papers</Badge>
        <h2 class="font-display text-3xl font-bold text-foreground">
          Start from the paper.
        </h2>
        <p class="mt-3 max-w-2xl text-base leading-relaxed text-foreground-muted">
          These pages are supporting material. The paper gives the frame and links back here when the code or model matters.
        </p>
      </div>
      <Button variant="outline" href="/papers">
        View papers
        <Icon name="arrow-right" size="sm" />
      </Button>
    </div>
  </section>
</PageLayout>
