---
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import ContactForm from '@/components/patterns/ContactForm.astro';
import siteConfig from '@/config/site.config';
import { resolveSocialLinks } from '@/lib/utils';

const socialLinks = resolveSocialLinks(siteConfig.socialLinks);

const channels = [
  {
    icon: 'mail',
    label: 'Email',
    value: siteConfig.email,
    note: 'Best for PhD, lab, and technical conversations',
    href: `mailto:${siteConfig.email}`,
    external: false,
  },
  ...socialLinks.map((link) => ({
    icon: link.icon,
    label: link.label,
    value: link.href.replace(/^https?:\/\/(www\.)?/, ''),
    note: 'Artifacts and code',
    href: link.href,
    external: true,
  })),
];
---

<PageLayout
  title="Contact"
  description="Contact José Luis Delgado for research, lab, PhD, and technical engineering conversations."
  eagerReveal
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="mail" size="sm" />
      Contact
    </Badge>

    <h1 slot="title">
      A direct line for serious technical conversations.
    </h1>

    <p slot="description">
      Research fit, lab conversations, PhD applications, security artifacts,
      or engineering work that benefits from careful systems thinking.
    </p>
  </Hero>

  <section class="border-t border-border bg-background-secondary py-[var(--space-section-md)]">
    <div class="mx-auto grid max-w-6xl gap-10 px-6 lg:grid-cols-[1.15fr_0.85fr]">
      <Card padding="lg" class="h-full" data-reveal="right">
        <div class="mb-6 flex items-start justify-between gap-4">
          <div>
            <Badge variant="brand" pill class="mb-4">Message</Badge>
            <h2 class="font-display text-2xl font-bold text-foreground">Send a concise note</h2>
          </div>
          <div class="hidden h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 text-brand-500 sm:flex">
            <Icon name="send" size="md" />
          </div>
        </div>
        <p class="mb-8 text-sm leading-relaxed text-foreground-muted">
          The site is hosted statically on GitHub Pages, so this opens your email
          client with the message pre-filled instead of sending through a backend.
        </p>
        <ContactForm successMessage="Opening your email client..." />
      </Card>

      <div class="flex flex-col gap-4" data-reveal="left" data-reveal-delay="1">
        <div>
          <Badge variant="brand" pill class="mb-4">Channels</Badge>
          <h2 class="font-display text-2xl font-bold text-foreground">Where to look first</h2>
          <p class="mt-2 text-sm leading-relaxed text-foreground-muted">
            Email for intent, GitHub for artifacts, writing for research taste.
          </p>
        </div>

        {channels.map((ch) => (
          <a href={ch.href} {...ch.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}} class="group block">
            <Card hover padding="sm" class="h-full">
              <div class="flex items-center gap-3">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 text-brand-500">
                  <Icon name={ch.icon} size="sm" />
                </div>
                <div class="min-w-0 flex-1">
                  <p class="text-sm font-semibold text-foreground">{ch.label}</p>
                  <p class="truncate text-xs text-foreground-muted">{ch.value}</p>
                  <p class="mt-1 text-xs text-foreground-subtle">{ch.note}</p>
                </div>
                <Icon name="arrow-up-right" size="sm" class="shrink-0 text-foreground-muted transition-colors group-hover:text-brand-500" />
              </div>
            </Card>
          </a>
        ))}

        <Card hover padding="sm" class="border-brand-500/20 bg-brand-500/5">
          <div class="flex items-center gap-3">
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 text-brand-500">
              <Icon name="map-pin" size="sm" />
            </div>
            <div>
              <p class="text-sm font-semibold text-foreground">{siteConfig.address?.city ?? 'Madrid'}</p>
              <p class="mt-0.5 text-xs text-foreground-muted">Based in {siteConfig.address?.country ?? 'Spain'}, oriented toward US labs and remote collaboration.</p>
            </div>
          </div>
        </Card>

        <Button href="/projects" variant="outline" class="mt-2 self-start">
          Review artifacts first
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>
</PageLayout>
