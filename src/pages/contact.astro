---
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import ContactForm from '@/components/patterns/ContactForm.astro';
import siteConfig from '@/config/site.config';
import { resolveSocialLinks } from '@/lib/utils';

const socialLinks = resolveSocialLinks(siteConfig.socialLinks);

const channels = [
  {
    icon: 'mail',
    label: 'Email',
    value: siteConfig.email,
    note: 'Best for PhD, lab, and technical conversations',
    href: `mailto:${siteConfig.email}`,
    external: false,
  },
  ...socialLinks.map((link) => ({
    icon: link.icon,
    label: link.label,
    value: link.href.replace(/^https?:\/\/(www\.)?/, ''),
    note: 'Artifacts and code',
    href: link.href,
    external: true,
  })),
];
---

<PageLayout
  title="Contact"
  description="Contact José Luis Delgado for research, lab, PhD, and technical engineering conversations."
  eagerReveal
>
  <section class="bg-background-secondary pt-14 pb-8 md:pt-16 md:pb-10">
    <div class="mx-auto grid max-w-6xl gap-8 px-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div class="flex flex-col gap-5" data-reveal="right">
        <Badge variant="brand" pill class="self-start">
          <Icon name="mail" size="sm" />
          Contact
        </Badge>
        <h1 class="max-w-2xl font-display text-4xl font-bold leading-tight text-foreground md:text-5xl">
          Research contact.
        </h1>
        <p class="max-w-xl text-lg leading-relaxed text-foreground-muted">
          Lab conversations, PhD applications, security artifacts, and technical
          collaboration around systems security, formal methods, and cryptographic
          infrastructure.
        </p>
        <div class="flex flex-wrap gap-2 pt-2">
          <Badge variant="brand">Madrid</Badge>
          <Badge variant="brand">US labs</Badge>
          <Badge variant="brand">Remote collaboration</Badge>
        </div>
      </div>

      <Card padding="md" class="h-full" data-reveal="left">
        <div class="mb-4 flex items-start justify-between gap-4">
          <div>
            <Badge variant="brand" pill class="mb-4">Message</Badge>
            <h2 class="font-display text-2xl font-bold text-foreground">Send a note</h2>
          </div>
          <div class="hidden h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 text-brand-500 sm:flex">
            <Icon name="send" size="md" />
          </div>
        </div>
        <p class="mb-5 text-sm leading-relaxed text-foreground-muted">
          Opens a pre-filled email to {siteConfig.email}.
        </p>
        <ContactForm successMessage="Opening your email client..." />
      </Card>
    </div>
  </section>

  <section class="border-t border-border bg-background py-12">
    <div class="mx-auto grid max-w-6xl gap-8 px-6 lg:grid-cols-[0.9fr_1.1fr]">
      <div data-reveal>
        <Badge variant="brand" pill class="mb-4">Channels</Badge>
        <h2 class="font-display text-2xl font-bold text-foreground">Where the work lives</h2>
        <p class="mt-2 max-w-xl text-sm leading-relaxed text-foreground-muted">
          Email for conversations, GitHub for code, notes for technical context.
        </p>
      </div>

      <div class="grid gap-3 sm:grid-cols-2" data-reveal data-reveal-delay="1">
        {channels.map((ch) => (
          <a href={ch.href} {...ch.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}} class="group block">
            <Card hover padding="sm" class="h-full">
              <div class="flex items-center gap-3">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 text-brand-500">
                  <Icon name={ch.icon} size="sm" />
                </div>
                <div class="min-w-0 flex-1">
                  <p class="text-sm font-semibold text-foreground">{ch.label}</p>
                  <p class="truncate text-xs text-foreground-muted">{ch.value}</p>
                  <p class="mt-1 text-xs text-foreground-subtle">{ch.note}</p>
                </div>
                <Icon name="arrow-up-right" size="sm" class="shrink-0 text-foreground-muted transition-colors group-hover:text-brand-500" />
              </div>
            </Card>
          </a>
        ))}

        <Card hover padding="sm" class="border-brand-500/20 bg-brand-500/5">
          <div class="flex items-center gap-3">
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 text-brand-500">
              <Icon name="map-pin" size="sm" />
            </div>
            <div>
              <p class="text-sm font-semibold text-foreground">{siteConfig.address?.city ?? 'Madrid'}</p>
              <p class="mt-0.5 text-xs text-foreground-muted">Based in {siteConfig.address?.country ?? 'Spain'}.</p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>
</PageLayout>
