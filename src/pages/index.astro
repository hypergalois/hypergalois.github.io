---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
import { getCollection } from 'astro:content';

const projectItems = await getCollection('projects', ({ data }) => !data.draft);
const featuredProjects = projectItems
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .filter((post) => post.data.locale === 'en')
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
  })
  .slice(0, 3);

const researchDirections = (await getCollection('topics'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((topic) => topic.data);

const focusAreas = [
  'Post-quantum TLS and certificate assurance',
  'Protocol boundary testing and measurement',
  'Lean / formal models for security arguments',
  'Evaluation harnesses for automated research workflows',
];
---

<LandingLayout
  title="Research engineering portfolio"
  description="A technical portfolio for systems security, formal methods, cryptographic infrastructure, and research-grade engineering."
  image="/og-default.svg"
  includePersonSchema={true}
>
  <Hero layout="centered" size="xl" class="hero-dark-gradient" showScrollIndicator>
    <Badge slot="badge" variant="brand" pill pulse class="dark:text-brand-200">
      Hypergalois · Systems security · Formal methods · Cryptographic infrastructure
    </Badge>

    <h1 slot="title" class="!text-[2.625rem] sm:!text-5xl md:!text-6xl lg:!text-7xl">
      <span class="text-brand-700 dark:text-foreground [-webkit-text-fill-color:currentColor]">José Luis Delgado</span><br />
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">Research engineering for</span><br />
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">critical systems.</span>
    </h1>

    <p slot="description">
      A portfolio for high-assurance work at the edge of security, verification, cryptography, and AI tooling:
      precise enough for labs, practical enough for real systems.
    </p>

    <Fragment slot="actions">
      <Button size="lg" href="/projects">
        Explore work
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button size="lg" variant="outline" href="/blog">
        <Icon name="book-open" size="sm" />
        Read notes
      </Button>
    </Fragment>

    <div class="mt-10 grid w-full max-w-4xl gap-3 sm:grid-cols-3">
      {['PhD / lab fit', 'Security research', 'Engineering taste'].map((label) => (
        <div class="rounded-xl border border-white/10 bg-white/[0.04] px-4 py-3 text-left shadow-lg backdrop-blur" data-reveal>
          <p class="text-xs font-semibold uppercase tracking-wider text-brand-200">{label}</p>
          <p class="mt-1 text-sm text-white/70">Rigorous, fast, readable.</p>
        </div>
      ))}
    </div>
  </Hero>

  <section id="research" class="relative z-10 border-t border-border bg-background-secondary py-[var(--space-section-md)]">
    <div class="mx-auto flex max-w-6xl flex-col gap-8 px-6">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.4fr]" data-reveal>
        <div class="flex flex-col gap-5">
          <Badge variant="brand" pill class="self-start">Research direction</Badge>
          <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
            Work that sits between proof, measurement, and systems.
          </h2>
        </div>
        <p class="text-lg leading-relaxed text-foreground-muted">
          The site is organized around a simple standard: show the problem, the model,
          the artifact, and the evidence. That keeps the portfolio readable for PhD
          committees, research labs, and teams that care about serious engineering.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {researchDirections.map((item, index) => (
          <Card hover href={item.href} data-reveal data-reveal-delay={index} class="group">
            <div class="flex h-full flex-col gap-5">
              <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500/25 to-brand-500/5 text-brand-500">
                <Icon name={item.icon} size="md" />
              </div>
              <div>
                <h3 class="text-base font-semibold text-foreground">{item.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-foreground-muted">{item.body}</p>
              </div>
              <div class="mt-auto inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 transition-colors group-hover:text-brand-400">
                Read related notes
                <Icon name="arrow-right" size="sm" />
              </div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="relative z-10 border-t border-border bg-background py-[var(--space-section-md)]">
    <div class="mx-auto flex max-w-6xl flex-col gap-8 px-6">
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between" data-reveal>
        <div class="flex flex-col gap-5">
          <Badge variant="brand" pill class="self-start">Selected systems</Badge>
          <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
            Research artifacts, not just screenshots.
          </h2>
        </div>
        <a href="/projects" class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 transition-colors hover:text-brand-600">
          View all projects
          <Icon name="arrow-right" size="sm" />
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {featuredProjects.map((project) => (
          <Card variant="elevated" hover padding="lg" href={`/projects/${project.id.replace(/\.mdx?$/, '')}`} class="group flex flex-col" data-reveal>
            <div class="mb-4 flex items-start justify-between gap-4">
              <div class="flex flex-wrap gap-1.5">
                {project.data.tags.slice(0, 3).map((tag) => (
                  <Badge variant="brand">{tag}</Badge>
                ))}
              </div>
              <Icon name="arrow-up-right" size="sm" class="shrink-0 text-foreground-muted transition-colors group-hover:text-brand-500" />
            </div>
            <div class="mb-2 flex items-baseline gap-2">
              <h3 class="font-display text-xl font-bold text-foreground">{project.data.title}</h3>
              {project.data.year && <span class="text-xs text-foreground-muted">{project.data.year}</span>}
            </div>
            <p class="flex-1 text-sm leading-relaxed text-foreground-muted">{project.data.description}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="relative z-10 border-t border-border bg-background-secondary py-[var(--space-section-md)]">
    <div class="mx-auto grid max-w-6xl gap-8 px-6 lg:grid-cols-[1fr_1.2fr]">
      <Card variant="elevated" padding="lg" class="overflow-hidden" data-reveal="right">
        <Badge variant="brand" pill class="mb-6">Current focus</Badge>
        <h2 class="font-display text-3xl font-bold text-foreground">
          Building a portfolio around technical credibility.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-foreground-muted">
          The design keeps the speed and polish of the template, but changes the signal:
          projects become artifacts, posts become research notes, and the homepage reads
          like an editorial index rather than a sales page.
        </p>
      </Card>

      <div class="grid gap-3" data-reveal="left" data-reveal-delay="1">
        {focusAreas.map((item, index) => (
          <div class="group flex items-center justify-between gap-4 rounded-xl border border-border bg-background px-5 py-4 shadow-sm transition-all hover:-translate-y-0.5 hover:border-brand-500/60 hover:shadow-md">
            <div class="flex items-center gap-4">
              <span class="font-mono text-xs text-brand-500">0{index + 1}</span>
              <p class="text-sm font-medium text-foreground">{item}</p>
            </div>
            <Icon name="chevron-right" size="sm" class="shrink-0 text-foreground-subtle transition-colors group-hover:text-brand-500" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="relative z-10 border-t border-border bg-background py-[var(--space-section-md)]">
    <div class="mx-auto flex max-w-6xl flex-col gap-8 px-6">
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between" data-reveal>
        <div class="flex flex-col gap-5">
          <Badge variant="brand" pill class="self-start">Writing</Badge>
          <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
            Notes with enough detail to be useful.
          </h2>
        </div>
        <a href="/blog" class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 transition-colors hover:text-brand-600">
          View all notes
          <Icon name="arrow-right" size="sm" />
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            href={`/blog/${post.id.replace('en/', '')}`}
            publishedAt={post.data.publishedAt}
            tags={post.data.tags}
            author={post.data.author}
            image={post.data.image}
            svgSlug={post.data.svgSlug}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="relative z-10 border-t border-border bg-background py-[var(--space-section-md)]">
    <div class="glitch:hidden mx-auto max-w-2xl px-6 text-center" data-reveal>
      <Badge variant="brand" pill class="mb-6">Next step</Badge>
      <h2 class="mb-4 font-display text-4xl font-bold text-foreground text-balance">
        A sharper technical presence.
      </h2>
      <p class="mb-8 text-lg text-foreground-muted text-balance">
        Built for labs, research teams, and PhD applications where taste and evidence both matter.
      </p>
      <Button size="lg" href="/contact" class="cta-btn-brand">
        Get in touch
        <Icon name="arrow-right" size="sm" />
      </Button>
    </div>

    <LetterGlitchBand>
      <h2 class="mb-4 font-display text-4xl font-bold text-foreground text-balance">
        A sharper technical presence.
      </h2>
      <p class="mb-8 text-lg text-foreground-muted text-balance">
        Built for labs, research teams, and PhD applications where taste and evidence both matter.
      </p>
      <div class="flex flex-col justify-center gap-4 sm:flex-row">
        <Button size="lg" href="/contact" class="hero-btn-brand">
          Get in touch
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/about">
          Profile
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </LetterGlitchBand>
  </section>
</LandingLayout>
