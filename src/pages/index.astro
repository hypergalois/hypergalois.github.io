---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { researchLines } from '@/data/researchLines';
import { getCollection } from 'astro:content';

const paperItems = (await getCollection('papers', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const slug = (id: string) => id.replace(/^en\//, '').replace(/\.mdx?$/, '');
const paperHref = (id: string) => `/papers/${slug(id)}`;

const lineGroups = researchLines.map((line) => ({
  ...line,
  papers: paperItems.filter((paper) => paper.data.line === line.id).slice(0, 4),
}));
---

<LandingLayout
  title="José Luis Delgado — Research engineering portfolio"
  description="A technical portfolio for systems security, formal methods, cryptographic infrastructure, AI evaluation, and research-grade engineering."
  image="/og-default.svg"
  includePersonSchema={true}
>
  <Hero layout="centered" size="xl" class="hero-dark-gradient" showScrollIndicator>
    <Badge slot="badge" variant="brand" pill pulse class="dark:text-brand-200">
      Systems security · Formal methods · Cryptographic infrastructure
    </Badge>

    <h1 slot="title" class="!text-[2.625rem] sm:!text-5xl md:!text-6xl lg:!text-7xl">
      <span class="block text-brand-200 [-webkit-text-fill-color:currentColor]">José Luis Delgado</span>
      <span class="mt-3 block text-white [-webkit-text-fill-color:currentColor]">Research engineering for</span>
      <span class="block text-white [-webkit-text-fill-color:currentColor]">critical systems.</span>
    </h1>

    <p slot="description">
      Work across deployed security systems, cryptographic migration, formal models,
      and evaluation infrastructure for AI-assisted research.
    </p>

    <Fragment slot="actions">
      <Button size="lg" href="/papers">
        <Icon name="file-text" size="sm" />
        Papers
      </Button>
      <Button size="lg" variant="outline" href="/about">
        About
        <Icon name="arrow-right" size="sm" />
      </Button>
    </Fragment>

    <div class="mt-14 grid w-full max-w-4xl gap-4 md:grid-cols-2">
      {lineGroups.map((line) => (
        <a
          href={`#${line.id}`}
          class="group rounded-lg border border-white/20 bg-white/[0.06] p-6 text-left shadow-xl ring-1 ring-white/[0.04] backdrop-blur transition-all hover:-translate-y-0.5 hover:border-brand-200/80 hover:bg-white/[0.10]"
          data-reveal
        >
          <div class="flex items-start justify-between gap-5">
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-brand-200">{line.eyebrow}</p>
              <h2 class="mt-2 font-display text-2xl font-bold text-white">{line.shortTitle}</h2>
            </div>
            <Icon name={line.icon} size="lg" class="shrink-0 text-brand-200" />
          </div>
          <p class="mt-4 text-sm leading-relaxed text-white/72">{line.description}</p>
          <div class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium text-brand-200 transition-colors group-hover:text-white">
            View line
            <Icon name="arrow-right" size="sm" />
          </div>
        </a>
      ))}
    </div>
  </Hero>

  {lineGroups.map((line, index) => (
    <section
      id={line.id}
      class={`relative z-10 border-t border-border ${index % 2 === 0 ? 'bg-background-secondary' : 'bg-background'} py-[var(--space-section-lg)]`}
    >
      <div class="mx-auto flex max-w-6xl flex-col gap-12 px-6">
        <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr]" data-reveal>
          <div class="flex flex-col gap-5">
            <Badge variant="brand" pill class="self-start">{line.eyebrow}</Badge>
            <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
              {line.title}
            </h2>
          </div>

          <div class="self-end">
            <p class="text-lg leading-relaxed text-foreground-muted">
              {line.evidence}
            </p>
            <div class="mt-5 flex flex-wrap gap-2">
              {line.objects.map((object) => <Badge variant="brand">{object}</Badge>)}
            </div>
          </div>
        </div>

        {line.papers.length > 0 ? (
          <div class="grid gap-5 md:grid-cols-2">
            {line.papers.map((paper) => (
              <Card variant="elevated" padding="lg" class="group flex min-h-[18rem] flex-col border-border-strong bg-background-tertiary/70" data-reveal>
                <div class="flex h-full flex-col gap-6">
                  <div>
                    <div class="mb-4 flex flex-wrap gap-1.5">
                      <Badge variant="brand">{paper.data.status}</Badge>
                      {paper.data.year && <Badge>{paper.data.year}</Badge>}
                    </div>
                    <a href={paperHref(paper.id)} class="font-display text-2xl font-bold leading-tight text-foreground transition-colors group-hover:text-brand-500">
                      {paper.data.title}
                    </a>
                    <p class="mt-3 text-sm leading-relaxed text-foreground-muted">{paper.data.description}</p>
                  </div>
                  <div class="mt-auto flex flex-wrap gap-2">
                    <Button size="sm" href={paperHref(paper.id)}>
                      <Icon name="file-text" size="sm" />
                      Read paper
                    </Button>
                    {paper.data.link && (
                      <Button size="sm" variant="outline" href={paper.data.link} target="_blank" rel="noopener noreferrer">
                        <Icon name="external-link" size="sm" />
                        Link
                      </Button>
                    )}
                    {paper.data.pdf && (
                      <Button size="sm" variant="outline" href={paper.data.pdf} target="_blank" rel="noopener noreferrer">
                        <Icon name="file-down" size="sm" />
                        PDF
                      </Button>
                    )}
                    {paper.data.repo && (
                      <Button size="sm" variant="outline" href={paper.data.repo} target="_blank" rel="noopener noreferrer">
                        <Icon name="github" size="sm" />
                        Code
                      </Button>
                    )}
                  </div>
                </div>
              </Card>
            ))}
          </div>
        ) : (
          <Card padding="lg" data-reveal>
            <p class="text-sm leading-relaxed text-foreground-muted">
              Papers for this line will appear here.
            </p>
          </Card>
        )}
      </div>
    </section>
  ))}

  <section class="relative z-10 border-t border-border bg-background-secondary py-[var(--space-section-md)]">
    <div class="mx-auto flex max-w-5xl flex-col gap-6 px-6 md:flex-row md:items-center md:justify-between" data-reveal>
      <div>
        <Badge variant="brand" pill class="mb-5">Contact</Badge>
        <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
          Research conversations.
        </h2>
        <p class="mt-3 max-w-2xl text-base leading-relaxed text-foreground-muted">
          Email for PhD, lab, engineering, and collaboration conversations.
        </p>
      </div>
      <Button size="lg" href="/contact">
        Contact
        <Icon name="arrow-right" size="sm" />
      </Button>
    </div>
  </section>
</LandingLayout>
