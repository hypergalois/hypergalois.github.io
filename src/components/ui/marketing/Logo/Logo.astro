---
/**
 * Logo Component
 *
 * Mathematical sigil used across nav, footer, favicon-adjacent surfaces, and
 * author bylines.
 */
import { cn } from '@/lib/cn';
import siteConfig from '@/config/site.config';

interface Props {
  /** Size preset */
  size?: 'sm' | 'md' | 'lg' | 'xl' | '2xl';
  /** Force dark mode logo (for dark backgrounds) — no-op here, kept for API compat */
  forceDark?: boolean;
  /** Use full logo instead of logomark — no-op here, kept for API compat */
  variant?: 'logomark' | 'full';
  /** Additional CSS classes */
  class?: string;
  /** Kept for compatibility with old author-avatar calls. */
  letter?: string;
}

const {
  size = 'md',
  class: className,
} = Astro.props;

const sizeClasses: Record<string, string> = {
  sm: 'w-5 h-5',
  md: 'w-6 h-6',
  lg: 'w-8 h-8',
  xl: 'w-12 h-12',
  '2xl': 'w-24 h-24',
};

const box = sizeClasses[size] ?? sizeClasses.md;
---

<span
  class={cn(
    'inline-flex shrink-0 items-center justify-center text-brand-500',
    box,
    className
  )}
  aria-label={siteConfig.branding.logo.alt}
  role="img"
>
  <svg viewBox="0 0 48 48" class="h-full w-full" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect x="1.5" y="1.5" width="45" height="45" rx="9" class="fill-background stroke-current" stroke-width="2" />
    <path d="M24 6.5 38.5 24 24 41.5 9.5 24 24 6.5Z" stroke="currentColor" stroke-width="2.1" stroke-linejoin="round" />
    <path d="M24 12.5 33.5 24 24 35.5 14.5 24 24 12.5Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" opacity=".72" />
    <path d="M9.5 24h29M24 6.5v35" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity=".5" />
    <circle cx="24" cy="24" r="3.2" class="fill-current" />
    <circle cx="24" cy="6.5" r="1.9" class="fill-current" />
    <circle cx="38.5" cy="24" r="1.9" class="fill-current" />
    <circle cx="24" cy="41.5" r="1.9" class="fill-current" />
    <circle cx="9.5" cy="24" r="1.9" class="fill-current" />
  </svg>
</span>
